{
  "name": "@homenshum/nodetrace",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Portable Trace Lens UI and SQLite setup for agent-native apps.",
  "repository": {
    "type": "git",
    "url": "https://github.com/HomenShum/nodetrace.git"
  },
  "bin": {
    "nodetrace": "./bin/nodetrace.mjs",
    "nodetrace-capture": "./bin/nodetrace-capture.mjs",
    "nodetrace-mcp": "./bin/nodetrace-mcp.mjs"
  },
  "keywords": [
    "agent",
    "trace",
    "trace-lens",
    "sqlite",
    "react",
    "coding-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".claude/",
    "bin/",
    "db/",
    "docs/",
    "examples/",
    "public/",
    "scripts/",
    "src/",
    "index.html",
    "vite.config.ts",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "db:init": "node scripts/init-sqlite.mjs",
    "happy-path": "node scripts/init-sqlite.mjs --json-out docs/eval/nodetrace-happy-path.json",
    "builder:smoke": "node scripts/builder-access-smoke.mjs",
    "agent:scale:smoke": "node scripts/agent-trace-scale-smoke.mjs",
    "understand:noderoom": "node scripts/understand-anything-noderoom.mjs",
    "capture:plan:smoke": "node bin/nodetrace.mjs capture --plan examples/real-codebase-capture/noderoom.capture.json --dry-run",
    "capture:noderoom:real": "node scripts/capture-noderoom-real-assets.mjs",
    "trace-coach:sqlite": "node scripts/trace-coach-sqlite.mjs --json-out docs/eval/nodetrace-trace-coach-sqlite.json",
    "installer:next:e2e": "node scripts/installer-next-e2e-smoke.mjs",
    "package:dry-run": "npm pack --dry-run",
    "walkthroughs:render": "node scripts/render-walkthrough-media.mjs",
    "mcp:smoke": "node scripts/mcp-smoke.mjs",
    "smoke": "node scripts/smoke.mjs && node scripts/cli-smoke.mjs && node scripts/mcp-smoke.mjs",
    "prepush": "npm run happy-path && npm run smoke && npm run builder:smoke && npm run agent:scale:smoke && npm run capture:plan:smoke && npm run trace-coach:sqlite && npm run installer:next:e2e && npm run build && npm run package:dry-run && npm audit --omit=dev"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^0.515.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
